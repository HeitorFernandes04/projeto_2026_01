# --- BACKEND CORE (DJANGO) ---
DEBUG=True
SECRET_KEY=substitua_por_uma_chave_segura_local
ALLOWED_HOSTS=localhost,127.0.0.1
# (Manter configurações locais efêmeras/RAM para o SQLite nesta sprint)
DATABASE_URL=sqlite:///db.sqlite3

# --- CELERY E CACHE ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# --- CONFIGURAÇÃO DE E-MAIL ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu_email@gmail.com
EMAIL_HOST_PASSWORD=sua_senha_de_app

# --- FRONTEND ---
FRONTEND_BASE_URL=http://localhost:5173


# --- GATEWAY WHATSAPP (EVOLUTION API NATIVA) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_secreta_aqui
EVOLUTION_INSTANCE_NAME=sua_instancia

# --- BANCO DE DADOS DA MENSAGERIA NATIVA ---
EVOLUTION_DB_PORT=5433
EVOLUTION_DB_USER=postgres
EVOLUTION_DB_PASSWORD=evolution_pass_local
EVOLUTION_DB_NAME=evolution_prod

# =====================================================================
# DOCUMENTAÇÃO ARQUITETURAL E PLANO DE TRANSIÇÃO
# =====================================================================
#
# AMBIENTE LOCAL ATUAL:
# O monólito Django roda sobre SQLite em RAM/efêmero, facilitando o
# desenvolvimento B2C (mobile-cliente) e B2B (web-gestor).
# No entanto, a Evolution API necessita do banco PostgreSQL (`db-evolution`)
# ativo de forma isolada via `docker-compose.evolution.yml` para 
# persistir os tokens de pareamento das instâncias do WhatsApp.
#
# TRANSIÇÃO PARA PRODUÇÃO (NUVEM):
# Conforme o nosso PLANO_FINALIZACAO.md e deploy_producao.md, 
# abandonaremos o SQLite no momento do Deploy. A infraestrutura produtiva 
# será totalmente orquestrada em uma rede isolada via Docker Compose 
# unificado contendo 5 contêineres essenciais integrados:
# 
# 1. db: PostgreSQL unificado (SaaS Core).
# 2. redis: Cache / OTP / Throttling.
# 3. backend: Django via ASGI/Uvicorn.
# 4. web: Nginx servindo o build Angular.
# 5. gateway-ssl: Proxy reverso principal com Certbot/Caddy.
# (Além do próprio container do evolution-api em rede interna).
# =====================================================================
